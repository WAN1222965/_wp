        <div class="info-grid">
            <div class="info-item">
                <p><b>就讀學校：</b><br>國立金門大學</p>
            </div>
            <div class="info-item">
                <p><b>電子郵件：</b><br><a href="mailto:s111410509@studrnt.nqu.edu.tw">s111410509@studrnt.nqu.edu.tw</a></p>
            </div>
        </div>
    </section>

    <section class="card">
        <h2>專長與核心技能</h2>
        <div class="tag-container">
            <span class="tag">羽球 (Badminton)</span>
            <span class="tag">C / C++ 程式設計</span>
